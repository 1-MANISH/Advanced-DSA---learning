      "boundElements": null,
      "updated": 1777016085959,
      "link": null,
      "locked": false,
      "text": "36\n\ni = 1 ------> j = 36/1 => 36\ni = 2 ------> j = 36/2 => 18\ni = 3 -------> j = 36/3 => 12\ni = 4 -------> j = 36/4 => 9\ni = 5 ❌\ni = 6 -------> j = 36/6 => 6\ni = 7 ❌\ni = 8 ❌\ni = 9 -------> j = 36/9 => 4\ni = 10 ❌\ni = 11 ❌\ni = 12 ------> j = 36/12 =>3\ni = 13 ❌\ni = 14 ❌\ni = 16 ❌\ni = 17 ❌\ni = 18 -------> j = 36/18 => 2\ni = 19 ❌\ni = 20 ❌\ni = 21 ❌\ni = 22 ❌\n.\n.\ni = 36 ------> j = 36/1 => 36",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "36\n\ni = 1 ------> j = 36/1 => 36\ni = 2 ------> j = 36/2 => 18\ni = 3 -------> j = 36/3 => 12\ni = 4 -------> j = 36/4 => 9\ni = 5 ❌\ni = 6 -------> j = 36/6 => 6\ni = 7 ❌\ni = 8 ❌\ni = 9 -------> j = 36/9 => 4\ni = 10 ❌\ni = 11 ❌\ni = 12 ------> j = 36/12 =>3\ni = 13 ❌\ni = 14 ❌\ni = 16 ❌\ni = 17 ❌\ni = 18 -------> j = 36/18 => 2\ni = 19 ❌\ni = 20 ❌\ni = 21 ❌\ni = 22 ❌\n.\n.\ni = 36 ------> j = 36/1 => 36",
      "autoResize": true,
      "lineHeight": 1.25
    },
