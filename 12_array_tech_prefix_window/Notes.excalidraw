      "containerId": null,
      "originalText": "log2(10) = > 3.4===4\n\nlog2(10^2) => 6.7 ===7\n\nlog2(10^3)==> 9.9===10\n\nlog2(10^18)==> 59===60",
      "autoResize": true,
      "lineHeight": 1.15
    },
