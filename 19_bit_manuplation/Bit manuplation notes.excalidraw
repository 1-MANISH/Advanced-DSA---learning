      "isDeleted": false,
      "boundElements": [],
      "updated": 1780296387898,
      "link": null,
      "locked": false,
      "text": "for(i = 30 ; i>=0 ; i--){\n\n    if(checkIthBit(n,i)){\n        count++\n    }\n\n}\n\nreturn count==1",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "for(i = 30 ; i>=0 ; i--){\n\n    if(checkIthBit(n,i)){\n        count++\n    }\n\n}\n\nreturn count==1",
      "autoResize": true,
      "lineHeight": 1.25
    },
