    {
      "id": "hg9eCl90c2JYy92ulP2WH",
      "type": "text",
      "x": 244.52394104003906,
      "y": 26860,
      "width": 567.1798095703125,
      "height": 675,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "c04R",
      "roundness": null,
      "seed": 1768767740,
      "version": 269,
      "versionNonce": 1901928644,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780296319643,
      "link": null,
      "locked": false,
      "text": "checkIthBit (n,i)\n    mask = 1 << i\n    return (n & mask) ==0 ? 0 :1 \n\nsetIthBit(n,i)\n    mask = 1 << i\n    return (n | mask)\n\ntoggleIthBit(n,i)\n    mask = 1 << i\n    return (n ^ mask)\n\nunsetIthBit(n,i)\n    mask = ~(1 << i)\n    return (n & mask)",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "checkIthBit (n,i)\n    mask = 1 << i\n    return (n & mask) ==0 ? 0 :1 \n\nsetIthBit(n,i)\n    mask = 1 << i\n    return (n | mask)\n\ntoggleIthBit(n,i)\n    mask = 1 << i\n    return (n ^ mask)\n\nunsetIthBit(n,i)\n    mask = ~(1 << i)\n    return (n & mask)",
      "autoResize": true,
      "lineHeight": 1.25
    },
