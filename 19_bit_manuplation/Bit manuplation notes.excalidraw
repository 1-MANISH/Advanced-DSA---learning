      "text": "Given a number N\n\ncheck if its a power of 2 or not\n\n",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Given a number N\n\ncheck if its a power of 2 or not\n\n",
