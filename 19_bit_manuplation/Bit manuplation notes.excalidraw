    {
      "id": "lMfQoQgRaGeOhDC7jGPd8",
      "type": "text",
      "x": 15.160000000000537,
      "y": 8110,
      "width": 840.8399999999995,
      "height": 585,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "cross-hatch",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bYG",
      "roundness": null,
      "seed": 1727975189,
      "version": 946,
      "versionNonce": 211492339,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776956825148,
      "link": null,
      "locked": false,
      "text": "app.get('/courseContent',authMiddleware,(req,res,_next)=>{\n\n\nconst userId  =  req.userId\nconst courseId = req.query.courseId\n\nconst course = await prisma.courses.findFirst({where:{\n    id:courseId\n}})\n\nif(!courseId) res.status(401).json({})\n\nconst purchaseDetail = await prisma.purchases.find({where:{\n    userId,\n    courseId\n}})\n\nif(!purchaseDetail ) res.status(401).json({})\n\n// check validity\n\nif(purchaseDetail.createdAt + course.validityy*3600Z*24*12 <= Date.now()) res.status(401).json({})\n\nconst courseContent  =  await prisma.videos.find({where:{\n    courseId\n}}) \n\nreturn res.status(200).json({courseContent})\n\n})",
      "fontSize": 15.59999999999999,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "app.get('/courseContent',authMiddleware,(req,res,_next)=>{\n\n\nconst userId  =  req.userId\nconst courseId = req.query.courseId\n\nconst course = await prisma.courses.findFirst({where:{\n    id:courseId\n}})\n\nif(!courseId) res.status(401).json({})\n\nconst purchaseDetail = await prisma.purchases.find({where:{\n    userId,\n    courseId\n}})\n\nif(!purchaseDetail ) res.status(401).json({})\n\n// check validity\n\nif(purchaseDetail.createdAt + course.validityy*3600Z*24*12 <= Date.now()) res.status(401).json({})\n\nconst courseContent  =  await prisma.videos.find({where:{\n    courseId\n}}) \n\nreturn res.status(200).json({courseContent})\n\n})",
      "autoResize": true,
      "lineHeight": 1.25
    },
